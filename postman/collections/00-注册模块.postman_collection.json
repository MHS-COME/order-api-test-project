          "raw": "{\n  \"username\": \"newuser3\",\n  \"password\": \"Test@123456\",\n  \"email\": \"invalid-email\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/register",
          "host": [
            "{{base_url}}"
          ],
