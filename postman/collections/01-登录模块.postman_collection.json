  "item": [
    {
      "name": "01-用户认证",
      "description": "POST /login 接口测试。含数据驱动模板(TC-LOGIN-DDT)及独立用例(TC-LOGIN-001~010)。",
      "item": [
        {
          "name": "TC-LOGIN-DDT [数据驱动] 登录接口数据驱动测试",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// ========================================",
                  "// 数据驱动测试脚本 — 从 CSV 读取期望值",
                  "// Newman 运行时: pm.iterationData 提供 CSV 行数据",
                  "// Postman 手动运行时: 回退到默认正向断言",
                  "// ========================================",
                  "",
                  "var expectedStatus = pm.iterationData.get(\"expected_status\");",
                  "var expectedCode = pm.iterationData.get(\"expected_code\");",
                  "var expectedMsgSub = pm.iterationData.get(\"expected_message_substring\");",
                  "",
                  "// 如果未通过 CSV 运行（Postman 手动调试），回退为正向断言",
                  "var isDataDriven = expectedStatus !== undefined && expectedStatus !== null && expectedStatus !== \"\";",
                  "",
                  "if (!isDataDriven) {",
                  "    expectedStatus = 200;",
                  "    expectedCode = 0;",
                  "    expectedMsgSub = \"success\";",
                  "}",
                  "",
                  "expectedStatus = parseInt(expectedStatus);",
                  "expectedCode = parseInt(expectedCode);",
                  "",
                  "// ---- 通用断言 ----",
                  "pm.test(\"[DDT] Status code is \" + expectedStatus, function () {",
                  "    pm.response.to.have.status(expectedStatus);",
                  "});",
                  "",
                  "pm.test(\"[DDT] Response time < 2000ms\", function () {",
                  "    pm.expect(pm.response.responseTime).to.be.below(2000);",
                  "});",
                  "",
                  "var jsonData = pm.response.json();",
                  "",
                  "pm.test(\"[DDT] code equals \" + expectedCode, function () {",
                  "    pm.expect(jsonData.code).to.eql(expectedCode);",
                  "});",
                  "",
                  "// ---- 消息子串断言（仅当 CSV 提供了期望值） ----",
                  "if (expectedMsgSub) {",
                  "    pm.test(\"[DDT] message contains '\" + expectedMsgSub + \"'\", function () {",
                  "        pm.expect(jsonData.message).to.be.a(\"string\");",
                  "        pm.expect(jsonData.message.toLowerCase()).to.include(expectedMsgSub.toLowerCase());",
                  "    });",
                  "}",
                  "",
                  "// ---- 仅登录成功时保存 token 并做额外断言 ----",
                  "if (expectedCode === 0) {",
                  "    pm.test(\"[DDT] data.token exists and is a non-empty string\", function () {",
                  "        pm.expect(jsonData.data).to.have.property(\"token\");",
                  "        pm.expect(jsonData.data.token).to.be.a(\"string\").and.not.empty;",
                  "        pm.environment.set(\"auth_token\", jsonData.data.token);",
                  "    });",
                  "",
                  "    pm.test(\"[DDT] data.tokenType equals Bearer\", function () {",
                  "        pm.expect(jsonData.data.tokenType).to.eql(\"Bearer\");",
                  "    });",
                  "",
                  "    pm.test(\"[DDT] data.expiresIn is a positive number\", function () {",
                  "        pm.expect(jsonData.data.expiresIn).to.be.a(\"number\").and.above(0);",
                  "    });",
                  "",
                  "    pm.test(\"[DDT] data.userId is a positive integer\", function () {",
                  "        pm.expect(jsonData.data.userId).to.be.a(\"number\").and.above(0);",
                  "    });",
                  "",
                  "    pm.test(\"[DDT] data.username is a non-empty string\", function () {",
                  "        pm.expect(jsonData.data.username).to.be.a(\"string\").and.not.empty;",
                  "    });",
                  "} else {",
                  "    // 登录失败时，确保响应中不含 token",
                  "    pm.test(\"[DDT] response body does NOT contain token\", function () {",
                  "        pm.expect(pm.response.text()).to.not.include(\"\\\"token\\\"\");",
                  "    });",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{input_username}}\",\n  \"password\": \"{{input_password}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/login",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "login"
              ]
            }
          },
          "response": []
        },
