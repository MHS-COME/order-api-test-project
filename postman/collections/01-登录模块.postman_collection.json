        {
          "name": "TC-LOGIN-011 [正向] 验证 JWT 格式（三段式）",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Response time < 2000ms\", function () {",
                  "    pm.expect(pm.response.responseTime).to.be.below(2000);",
                  "});",
                  "",
                  "var jsonData = pm.response.json();",
                  "",
                  "pm.test(\"code equals 0\", function () {",
                  "    pm.expect(jsonData.code).to.eql(0);",
                  "});",
                  "",
                  "pm.test(\"data.token is JWT format (3 segments)\", function () {",
                  "    var tok = jsonData.data.token;",
                  "    pm.expect(tok).to.be.a(\"string\").and.not.empty;",
                  "    var parts = tok.split('.');",
                  "    pm.expect(parts).to.have.lengthOf(3);",
                  "    pm.expect(parts[0]).to.not.be.empty;",
                  "    pm.expect(parts[1]).to.not.be.empty;",
                  "    pm.expect(parts[2]).to.not.be.empty;",
                  "    pm.environment.set(\"auth_token\", tok);",
                  "});",
                  "",
                  "pm.test(\"data.refreshToken is JWT format\", function () {",
                  "    var rt = jsonData.data.refreshToken;",
                  "    pm.expect(rt).to.be.a(\"string\").and.not.empty;",
                  "    var parts = rt.split('.');",
                  "    pm.expect(parts).to.have.lengthOf(3);",
                  "    pm.environment.set(\"refresh_token\", rt);",
                  "});",
                  "",
                  "pm.test(\"data.tokenType equals Bearer\", function () {",
                  "    pm.expect(jsonData.data.tokenType).to.eql(\"Bearer\");",
                  "});",
                  "",
                  "pm.test(\"data.expiresIn is 3600\", function () {",
                  "    pm.expect(jsonData.data.expiresIn).to.eql(3600);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{username}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/login",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "login"
              ]
            }
          },
          "response": []
        },
        {
          "name": "TC-REFRESH-001 [正向] 刷新 token 成功",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (!pm.environment.get('refresh_token')) {",
                  "  pm.sendRequest({",
                  "    url: pm.variables.get('base_url') + '/login',",
                  "    method: 'POST',",
                  "    header: { 'Content-Type': 'application/json' },",
                  "    body: { mode: 'raw', raw: JSON.stringify({ username: pm.variables.get('username'), password: pm.variables.get('password') }) }",
                  "  }, function(err, res) {",
                  "    if (!err) {",
                  "      var d = res.json().data;",
                  "      pm.environment.set('refresh_token', d.refreshToken);",
                  "    }",
                  "  });",
                  "}"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Response time < 2000ms\", function () {",
                  "    pm.expect(pm.response.responseTime).to.be.below(2000);",
                  "});",
                  "",
                  "var jsonData = pm.response.json();",
                  "",
                  "pm.test(\"code equals 0\", function () {",
                  "    pm.expect(jsonData.code).to.eql(0);",
                  "});",
                  "",
                  "pm.test(\"data.token is a valid JWT\", function () {",
                  "    pm.expect(jsonData.data.token).to.be.a(\"string\");",
                  "    pm.expect(jsonData.data.token.split('.')).to.have.lengthOf(3);",
                  "    pm.environment.set(\"auth_token\", jsonData.data.token);",
                  "});",
                  "",
                  "pm.test(\"data.tokenType equals Bearer\", function () {",
                  "    pm.expect(jsonData.data.tokenType).to.eql(\"Bearer\");",
                  "});",
                  "",
                  "pm.test(\"data.expiresIn is 3600\", function () {",
                  "    pm.expect(jsonData.data.expiresIn).to.eql(3600);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refresh_token}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/refresh",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "refresh"
              ]
            }
          },
          "response": []
        },
        {
          "name": "TC-REFRESH-002 [反向] 无效 refresh token",
