          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.sendRequest({",
              "  url: pm.variables.get('base_url') + '/test/expired-token',",
              "  method: 'GET'",
              "}, function(err, res) {",
              "  if (!err) {",
              "    var tok = res.json().data.token;",
